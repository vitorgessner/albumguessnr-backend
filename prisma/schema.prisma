// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  emailVerified       Boolean             @default(false)
  password            String
  createdAt           DateTime            @default(now())
  userStats           UserStats?
  profile             Profile?
  verificationToken   VerificationToken[]
  refreshToken        RefreshToken[]
  lastfmIntegrationId String?
  lastfmIntegration   LastFmIntegration?  @relation(fields: [lastfmIntegrationId], references: [id])
  userAlbumScores     UserAlbumScores[]
  userGuessAttempts   GuessAttempt[]
  userAlbumStats      UserAlbumStats[]
  sentRequests        UserFriends[]       @relation("sentRequests")
  receivedRequests    UserFriends[]       @relation("receivedRequests")
  failedAlbumsSync    FailedAlbumsSync[]
}

model UserStats {
  id                    String @id @default(uuid())
  userId                String @unique
  user                  User   @relation(fields: [userId], references: [id])
  totalScore            Int    @default(0)
  guessedDistinctAlbums Int    @default(0)
  guessedAlbums         Int    @default(0)
  rightGuessedAlbums    Int    @default(0)
  guessedArtists        Int    @default(0)
  rightGuessedArtist    Int    @default(0)
  guessedGenres         Int    @default(0)
  rightGuessedGenres    Int    @default(0)
  guessedYears          Int    @default(0)
  rightGuessedYears     Int    @default(0)
  guessedTracks         Int    @default(0)
  rightGuessedTracks    Int    @default(0)
}

model Profile {
  id         String   @id @default(uuid())
  username   String   @unique
  displayUsername String @default("")
  bio        String   @default("")
  avatar_url String
  updatedAt  DateTime @updatedAt
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  token          String   @id
  expirationTime DateTime
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  token          String   @id
  expirationTime DateTime
  userId         String
  user           User     @relation(fields: [userId], references: [id])
}

model LastFmIntegration {
  id                     String                 @id @default(uuid())
  lastfmUsername         String                 @unique
  lastfmDisplayUsername  String                 @default("")
  lastSyncedAt           DateTime
  lastPageSynced         Int                    @default(1)
  users                  User[]
  userAlbumFamiliarities UserAlbumFamiliarity[]
}

model GuessAttempt {
  id            String                 @id @default(uuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id])
  albumId       String
  album         Album                  @relation(fields: [albumId], references: [id])
  date          DateTime               @default(now())
  totalScore    Int                    @default(0)
  tracksHit     Int                    @default(0)
  timeSpent     Int
  categories    GuessAttemptCategory[]
  guessedTracks GuessedTrack[]

  @@index([userId, albumId, date])
  @@index([albumId])
}

model GuessedTrack {
  trackId        String
  track          Track        @relation(fields: [trackId], references: [id])
  guessAttemptId String
  guessAttempt   GuessAttempt @relation(fields: [guessAttemptId], references: [id])
  isCorrect      Boolean

  @@id([trackId, guessAttemptId])
}

model GuessAttemptCategory {
  id             String       @id @default(uuid())
  guessAttemptId String
  guessAttempt   GuessAttempt @relation(fields: [guessAttemptId], references: [id])
  category       GameCategory
  score          Int          @default(0)
}

model UserAlbumScores {
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  albumId   String
  album     Album        @relation(fields: [albumId], references: [id])
  gameMode  GameCategory
  date      DateTime     @db.Date
  bestScore Int          @default(0)

  @@id([userId, albumId, gameMode, date])
}

enum GameCategory {
  ALBUM
  ARTIST
  GENRE
  YEAR
  TRACKLIST
}

model UserAlbumStats {
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  albumId         String
  album           Album    @relation(fields: [albumId], references: [id])
  lastTimeGuessed DateTime
  timesGuessed    Int

  @@id([userId, albumId])
}

model UserAlbumFamiliarity {
  timesListened       Int
  tracksListened      Int
  lastTimeListened    DateTime
  albumId             String
  album               Album             @relation(fields: [albumId], references: [id])
  lastFmIntegrationId String
  lastFmIntegration   LastFmIntegration @relation(fields: [lastFmIntegrationId], references: [id])

  @@id([lastFmIntegrationId, albumId])
  @@index([lastFmIntegrationId])
}

model UserFriends {
  sentRequestsId     String
  sentRequests       User         @relation("sentRequests", fields: [sentRequestsId], references: [id])
  receivedRequestsId String
  receivedRequests   User         @relation("receivedRequests", fields: [receivedRequestsId], references: [id])
  stat               FriendsStats
  timesRequested     Int          @default(0)
  timesRejected      Int          @default(0)
  lastRequestedAt    DateTime     @default(now())

  @@id([sentRequestsId, receivedRequestsId])
}

enum FriendsStats {
  PENDING
  FRIEND
  DENIED
  CANCELLED_REQUEST
}

model Album {
  id                     String                 @id @default(uuid())
  mbid                   String?
  name                   String
  normalizedName         String
  normalizedArtist       String
  year                   String?
  cover_url              String
  genres                 AlbumsGenre[]
  artists                AlbumsArtist[]
  userAlbumFamiliarities UserAlbumFamiliarity[]
  userAlbumScores        UserAlbumScores[]
  guessAttempts          GuessAttempt[]
  userAlbumStats         UserAlbumStats[]
  tracks                 Track[]

  @@unique([normalizedName, normalizedArtist])
}

model Genre {
  id     String        @id @default(uuid())
  name   String        @unique
  albums AlbumsGenre[]
}

model AlbumsGenre {
  albumId String
  genreId String
  album   Album  @relation(fields: [albumId], references: [id])
  genre   Genre  @relation(fields: [genreId], references: [id])

  @@id([albumId, genreId])
}

model Artist {
  id             String         @id @default(uuid())
  mbid           String?
  name           String
  normalizedName String         @unique
  albums         AlbumsArtist[]
}

model AlbumsArtist {
  albumId  String
  artistId String
  album    Album  @relation(fields: [albumId], references: [id])
  artist   Artist @relation(fields: [artistId], references: [id])

  @@id([albumId, artistId])
}

model Track {
  id             String         @id @default(uuid())
  name           String
  normalizedName String
  albumId        String
  album          Album          @relation(fields: [albumId], references: [id])
  guessedTracks  GuessedTrack[]

  @@unique([normalizedName, albumId])
}

model FailedAlbumsSync {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumName String
  mbid String?
  artist String
  normalizedAlbum String
  cause Json
  status SyncStatus
  apiError PossibleApis
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([albumName, artist, apiError])
}

enum SyncStatus {
  PENDING
  RESOLVED
}

enum PossibleApis {
  LASTFM
  MUSICBRAINZ
}